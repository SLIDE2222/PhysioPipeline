{
    "name":  "physio-pipeline-backend",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "node --watch src/server.js",
                    "start":  "prisma generate --schema prisma/schema.prisma && prisma migrate deploy --schema prisma/schema.prisma && node tools/sync-clinic-schema.js && node src/server.js",
                    "prisma:generate":  "prisma generate --schema prisma/schema.prisma",
                    "prisma:migrate":  "prisma migrate dev --schema prisma/schema.prisma",
                    "prisma:studio":  "prisma studio",
                    "db:seed":  "node prisma/seed.js",
                    "taxonomy:build":  "node tools/build-search-taxonomy.js",
                    "build":  "prisma generate --schema prisma/schema.prisma && prisma migrate deploy --schema prisma/schema.prisma && node tools/sync-clinic-schema.js",
                    "postinstall":  "prisma generate --schema prisma/schema.prisma",
                    "prisma:push":  "prisma db push --schema prisma/schema.prisma",
                    "db:sync-clinic":  "node tools/sync-clinic-schema.js"
                },
    "dependencies":  {
                         "@prisma/client":  "^6.5.0",
                         "@supabase/supabase-js":  "^2.102.1",
                         "cookie-parser":  "^1.4.7",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.4.5",
                         "express":  "^4.21.2",
                         "jsonwebtoken":  "^9.0.2",
                         "nodemailer":  "^6.9.16",
                         "zod":  "^3.24.2",
                         "bcryptjs":  "^3.0.3"
                     },
    "devDependencies":  {
                            "prisma":  "^6.5.0"
                        }
}
