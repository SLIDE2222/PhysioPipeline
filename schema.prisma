generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum AccountType {
  physio
  clinic
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  emailVerified  Boolean   @default(false)
  accountType    AccountType @default(physio)
  name           String?
  phone          String?
  googleSub      String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  profiles       Profile[]
  clinicProfile  ClinicProfile?
  claimRequests  ClaimRequest[]
}

model ClinicProfile {
  id                  String               @id @default(cuid())
  userId              String?              @unique
  clinicName          String?
  responsibleName     String?
  address             String?
  city                String?
  neighborhood        String?
  phone               String?
  whatsapp            String?
  /// Backward-compatible serialized list. Legacy rows may still contain plain text.
  services            String?
  /// Serialized clinic physiotherapist team list for up to 5 professionals.
  physioTeam          String?
  logoUrl             String?
  description         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicClaimRequests ClinicClaimRequest[]
}

model Profile {
  id            String         @id @default(cuid())
  name          String
  specialty     String
  secondarySpecialty String?
  tertiarySpecialty String?
  city          String
  neighborhood  String?
  phone         String?
  bio           String?
  instagram     String?
  linkedin      String?
  photoUrl      String?
  publicEmail   String?
  attendance    String?
  isClaimed     Boolean        @default(false)
  ownerUserId   String?
  ownerUser     User?          @relation(fields: [ownerUserId], references: [id])
  claimRequests ClaimRequest[]
  leadEvents    LeadEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ClaimRequest {
  id           String      @id @default(cuid())
  profileId    String
  userId       String
  requestEmail String
  token        String      @unique
  status       ClaimStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@index([userId, status])
}

model ClinicClaimRequest {
  id                     String       @id @default(cuid())
  clinicProfileId        String
  clinicName             String?
  cnpj                   String
  responsibleName        String
  responsibleEmail       String
  whatsapp               String?
  roleOrRelation         String
  authorizationConfirmed Boolean      @default(false)
  proofFileName          String?
  proofFileMime          String?
  status                 ClaimStatus  @default(PENDING)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  clinicProfile ClinicProfile @relation(fields: [clinicProfileId], references: [id], onDelete: Cascade)

  @@index([clinicProfileId, status])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model LeadEvent {
  id        String   @id @default(cuid())
  profileId String
  type      String
  source    String?
  city      String?
  specialty String?
  createdAt DateTime @default(now())

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([type, createdAt])
}
