generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  physio
  clinic
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ClinicPhysioLinkStatus {
  PENDING
  ACCEPTED
  REJECTED
  UNLINKED
}

enum ReviewStatus {
  pending_owner
  pending_admin
  approved
  reported
  rejected
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  emailVerified  Boolean       @default(false)
  name           String?
  phone          String?
  accountType    AccountType   @default(physio)
  googleSub      String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  profiles       Profile[]
  clinicProfile  ClinicProfile?
  claimRequests  ClaimRequest[]
  reportedReviews ProfileReview[] @relation("ReviewReportedBy")
  moderatedReviews ProfileReview[] @relation("ReviewModeratedBy")
}

model Profile {
  id                 String         @id @default(cuid())
  name               String
  specialty          String
  secondarySpecialty String?
  tertiarySpecialty  String?
  city               String
  neighborhood       String?
  phone              String?
  bio                String?
  instagram          String?
  linkedin           String?
  photoUrl           String?
  publicEmail        String?
  attendance         String?
  isClaimed          Boolean        @default(false)
  ownerUserId        String?
  ownerUser          User?          @relation(fields: [ownerUserId], references: [id])
  claimRequests      ClaimRequest[]
  leadEvents         LeadEvent[]
  clinicLinks        ClinicPhysiotherapistLink[]
  reviews            ProfileReview[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model ProfileReview {
  id               String       @id @default(cuid())
  profileId        String
  authorName       String
  authorEmail      String?
  rating           Int?
  title            String?
  body             String
  status           ReviewStatus @default(pending_admin)
  reportReason     String?
  reportedAt       DateTime?
  reportedByUserId String?
  moderatedAt      DateTime?
  moderatedByUserId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  profile          Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reportedByUser   User?        @relation("ReviewReportedBy", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  moderatedByUser  User?        @relation("ReviewModeratedBy", fields: [moderatedByUserId], references: [id], onDelete: SetNull)

  @@index([profileId, status])
  @@index([status, createdAt])
}

model ClinicProfile {
  id                  String               @id @default(cuid())
  userId              String?              @unique
  clinicName          String?
  responsibleName     String?
  address             String?
  city                String?
  neighborhood        String?
  phone               String?
  whatsapp            String?
  services            String?
  physioTeam          String?
  logoUrl             String?
  description         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicClaimRequests ClinicClaimRequest[]
  physiotherapistLinks ClinicPhysiotherapistLink[]
}

model ClinicPhysiotherapistLink {
  id         String                  @id @default(cuid())
  clinicId  String
  profileId String
  status     ClinicPhysioLinkStatus @default(PENDING)
  message    String?
  readByClinic Boolean              @default(false)
  readByPhysio Boolean              @default(false)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  acceptedAt DateTime?
  rejectedAt DateTime?
  unlinkedAt DateTime?

  clinic  ClinicProfile @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  profile Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([clinicId, profileId])
  @@index([clinicId, status])
  @@index([profileId, status])
}

model ClaimRequest {
  id           String      @id @default(cuid())
  profileId    String
  userId       String
  requestEmail String
  token        String      @unique
  status       ClaimStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@index([userId, status])
}

model ClinicClaimRequest {
  id                     String        @id @default(cuid())
  clinicProfileId        String
  clinicName             String?
  cnpj                   String
  responsibleName        String
  responsibleEmail       String
  whatsapp               String?
  roleOrRelation         String
  authorizationConfirmed Boolean       @default(false)
  proofFileName          String?
  proofFileMime          String?
  status                 ClaimStatus   @default(PENDING)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  clinicProfile          ClinicProfile @relation(fields: [clinicProfileId], references: [id], onDelete: Cascade)

  @@index([clinicProfileId, status])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model LeadEvent {
  id        String   @id @default(cuid())
  profileId String
  type      String
  source    String?
  city      String?
  specialty String?
  createdAt DateTime @default(now())

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([type, createdAt])
}
